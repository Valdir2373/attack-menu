# ═══════════════════════════════════════════════════════════════════════════
# AttackMenu — Environment Variables
# Copie para .env e preencha os valores
# ════════════════════════════���═════════════════════════════���════════════════

# ── Encryption (obrigatório para ransom DB) ───────────────────────────────
KEY_CRIP_DATA=sua-chave-secreta-aqui

# ── C2 Relay Auth (opcional — vazio = open access) ────────────────────────
OPERATOR_TOKEN=

# ── GitHub Scraper (cookies de contas GitHub) ─────────────────────────────
COOKIE_GIT0=
COOKIE_GIT1=
COOKIE_GIT2=

# ── Portas (defaults) ────────────────────────────────────────────────────
PY_MANAGEMENT_PORT=4445
PY_PROXY_PORT=1212
RB_WS_PORT=4444
RB_HTTP_PORT=8080

# ── Debug ─────────────────────────────────────────────────────────────────
DEBUG=false
